# Approval policy: anything that moves money requires human approval when true.
REQUIRE_APPROVAL=true

# Azure Key Vault holding Plaid/bank credentials (see budget-infra), e.g. kvbudgetai<suffix>.
AZURE_KEY_VAULT_URI=https://<your-kv-name>.vault.azure.net/

# Tool service endpoints (local dev defaults).
AGGREGATOR_URL=http://localhost:8001
ANALYZER_URL=http://localhost:8002
PLANNER_URL=http://localhost:8003

# Azure Storage for plan + tracking data, e.g. stbudgetai<suffix>.
BUDGET_STORAGE_ACCOUNT=<your-storage-account>

# Azure OpenAI for the reasoning layer (/advise). Leave endpoint blank to disable.
# From budget-infra outputs (openAiEndpoint / openAiChatDeployment).
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview
